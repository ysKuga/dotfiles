{
  "enabledPlugins": {
    "genshijin@genshijin": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "genshijin": {
      "source": {
        "source": "github",
        "repo": "InterfaceX-co-jp/genshijin"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "language": "japanese",
  "theme": "dark",
  "permissions": {
    "deny": ["Read(**/.env)", "Read(**/.env.*)"]
  }
}
