{
  "enabledPlugins": {
    "genshijin@genshijin": true,
    "caveman@caveman": true
  },
  "extraKnownMarketplaces": {
    "genshijin": {
      "source": {
        "source": "github",
        "repo": "InterfaceX-co-jp/genshijin"
      }
    },
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    }
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$HOME/.claude/hooks/statusline.sh\""
  },
  "language": "japanese",
  "theme": "dark",
  "permissions": {
    "deny": ["Read(**/.env)", "Read(**/.env.*)"]
  },
  "hooks": {
    "PreBashCommand": [
      {
        "matcher": "npm install|npm i\\b|yarn install|yarn add|pnpm install|pnpm add|bun install|bun add",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/audit-repo.sh\" \"$(pwd)\"",
            "timeout": 30000
          }
        ]
      }
    ]
  }
}
